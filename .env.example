# Business Central API Configuration
# Copy this file to .env and fill in your values

# Your Azure AD tenant ID (GUID)
BC_TENANT=00000000-0000-0000-0000-000000000000

# Environment name (e.g., Sandbox, Production)
BC_ENV=Sandbox

# Company ID (GUID) - run ./scripts/list-companies.sh to find this
BC_COMPANY=00000000-0000-0000-0000-000000000000
